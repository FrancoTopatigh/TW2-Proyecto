generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

model Usuario {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  contrasena String
  nombre     String
  apellido   String
  direccion  String
  role       Role    @default(USER)
  pedidos    Pedido[]
}

model Producto {
  id            Int      @id @default(autoincrement())
  nombre        String
  descripcion   String
  clasificacion String
  precio        Float
  creadoPor     String?
  stock         Int 
  imagen        String?  @db.LongText
  detalles PedidoDetalle[] 
}

model Pedido {
  id        Int             @id @default(autoincrement())
  total     Float
  usuarioId Int        
  usuario   Usuario         @relation(fields: [usuarioId], references: [id])
  productos PedidoDetalle[] 
}

model PedidoDetalle {
  id         Int      @id @default(autoincrement())
  pedidoId   Int
  productoId Int
  cantidad   Int      
  precio     Float    

  pedido Pedido   @relation(fields: [pedidoId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])
}