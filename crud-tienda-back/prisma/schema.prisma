generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

model Usuario {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  contrasena String
  nombre     String
  apellido   String
  direccion  String
  role       Role    @default(USER)
  pedidos    Pedido[]
}

model Producto {
  id            Int      @id @default(autoincrement())
  nombre        String
  descripcion   String
  clasificacion String
  precio        Float
  creadoPor     String?
  stock         Int 
  pedidos       Pedido[] 
}

model Pedido {
  id        Int        @id @default(autoincrement())
  total     Float
  usuarioId Int        
  usuario   Usuario    @relation(fields: [usuarioId], references: [id])
  productos Producto[]
}